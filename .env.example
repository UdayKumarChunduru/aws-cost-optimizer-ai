# Region scanning.
# "ALL" triggers automatic active-region discovery via Cost Explorer
# (falls back to a per-region resource probe if Cost Explorer access
# is denied). Or specify exact regions: "us-east-1,ap-south-1"
AWS_REGIONS=ALL

# Scanner thresholds — every number here can be tuned without
# touching any Python file.
IDLE_CPU_THRESHOLD=5.0
IDLE_NETWORK_THRESHOLD=5000000
IDLE_LOOKBACK_DAYS=7
SNAPSHOT_MAX_AGE_DAYS=90
NAT_GATEWAY_BYTES_THRESHOLD=1000000
RDS_CONNECTION_LOOKBACK_DAYS=7
CLOUDWATCH_LOG_NO_RETENTION_MIN_AGE_DAYS=30
SECRETS_UNUSED_DAYS=90
ECR_UNTAGGED_AGE_DAYS=30

# Parallel scan tuning — see app/scanners/orchestrator.py
MAX_PARALLEL_REGIONS=10
MAX_PARALLEL_SCANNERS_PER_REGION=5
SCANNER_TIMEOUT_SECONDS=25

# Ollama — local FastAPI development only, never used by Lambda
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:4b

# Alerting — fill in your own values. Never commit a real email
# address to git; this file is a template only.
ALERT_EMAIL=your-email@example.com
# SNS_TOPIC_ARN is created and injected automatically by Terraform —
# leave empty here for local FastAPI use, which doesn't send SNS alerts.
SNS_TOPIC_ARN=

DYNAMODB_TABLE=cost-optimizer-findings

# Bedrock model — verify this exact ID is enabled in your account at
# https://console.aws.amazon.com/bedrock/home#/modelaccess
BEDROCK_MODEL_ID=anthropic.claude-haiku-4-5-20251001-v1:0
